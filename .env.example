# Meta Marketing API credentials
# Get from: Business Settings → System Users → Generate New Token
# Permissions required: ads_management, ads_read, business_management
META_ACCESS_TOKEN=YOUR_SYSTEM_USER_TOKEN_HERE

# App Secret from: developers.facebook.com → Your App → Settings → Basic → App Secret
# IMPORTANT: no trailing whitespace or newline
META_APP_SECRET=YOUR_APP_SECRET_HERE

# Business Manager ID (numeric)
# Get from: business.facebook.com → Settings → Business Info
META_BM_ID=1234567890

# Ad accounts to manage (JSON array)
# Get account IDs via Graph API Explorer: GET /me/adaccounts?fields=id,name
META_AD_ACCOUNTS=[{"id":"act_xxxxxxxxx","name":"Main Account","label":"Main"},{"id":"act_yyyyyyyyy","name":"Test Account","label":"Test"}]

# Your business name (shown in dashboard UI)
ORG_NAME=Your Business Name

# Optional: backend URL for local Next.js dev (defaults to localhost:8000)
# BACKEND_URL=http://localhost:8000
